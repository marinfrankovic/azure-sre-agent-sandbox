# Copy to .env and adjust. Consumed by `azd` and the deployment parameters.

# Target subscription for the sandbox.
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# azd environment name (used for deterministic resource naming).
AZURE_ENV_NAME=sreagent-sbx

# SRE Agent-supported region (swedencentral, uksouth, eastus2, australiaeast,
# francecentral, canadacentral, koreacentral). Validated by scripts/preflight-region.
AZURE_LOCATION=swedencentral

# Optional: override the resource group name (defaults to rg-<AZURE_ENV_NAME>-sre).
AZURE_RESOURCE_GROUP=

# Optional JSON object of tags applied to every resource.
AZURE_TAGS={"workload":"sre-agent-grafana","environment":"poc"}

# Private networking (recommended for security-conscious customers).
# true  = deploy a VNet, Private DNS zone, and a Grafana private endpoint.
# false = public endpoints only (no VNet / private endpoint).
ENABLE_PRIVATE_NETWORKING=true

# Grafana public network access (only applies when ENABLE_PRIVATE_NETWORKING=true).
# Disabled = private-endpoint-only (most secure).
# Enabled  = keep public access on AND add a private endpoint. Use this if the
#            Azure SRE Agent cannot reach a fully private Grafana.
GRAFANA_PUBLIC_NETWORK_ACCESS=Disabled
