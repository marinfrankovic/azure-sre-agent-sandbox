# Copy to .env and adjust. Consumed by `azd` and the deployment parameters.

# Target subscription for the sandbox (all resources deploy here).
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# azd environment name (used for deterministic resource naming).
AZURE_ENV_NAME=sreagent-sbx

# Any supported Azure region. Everything deploys into this region.
AZURE_LOCATION=westeurope

# Optional: override the resource group name (defaults to rg-<AZURE_ENV_NAME>-sre).
AZURE_RESOURCE_GROUP=

# Optional JSON object of tags applied to every resource.
AZURE_TAGS={"workload":"sre-agent-sandbox","environment":"poc"}
